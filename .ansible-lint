---
# ansible-lint configuration
# https://ansible.readthedocs.io/projects/lint/configuring/

rulesdir:
  - .ansible-lint-rules


# restore.yml uses `hosts: "{{ target_host }}"` intentionally — target_host is
# a required extra var passed at runtime (-e "target_host=..."). Provide a
# placeholder value so ansible-lint's syntax check can evaluate the playbook.
extra_vars:
  target_host: example
  restore_time: "2026-01-01 00:00:00"
  restore_confirm: "yes"
