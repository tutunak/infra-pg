# WAL-G environment configuration — managed by Ansible (walg role)
# Do not edit manually; changes will be overwritten.
export WALG_S3_PREFIX="s3://{{ walg_s3_bucket }}/wal-g"
export AWS_ENDPOINT="{{ walg_s3_endpoint }}"
export AWS_REGION="{{ walg_s3_region }}"
export AWS_ACCESS_KEY_ID="{{ walg_s3_access_key }}"
export AWS_SECRET_ACCESS_KEY="{{ walg_s3_secret_key }}"
export PGDATA="{{ pg_data_dir }}"
export PGHOST="/var/run/postgresql"
export PGUSER="postgres"
